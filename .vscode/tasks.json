{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean",
            "type": "shell",
            "command": "rm -rf build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Debug Build",
            "type": "shell",
            "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Release Build",
            "type": "shell",
            "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Library Only",
            "type": "shell",
            "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build --target mediacontroller",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Android Debug Build",
            "type": "shell",
            "command": ". \"$HOME/shared/platforms/android/env.sh\" && echo '=== Building for ANDROID ===' && cmake -S . -B build-android -DCMAKE_BUILD_TYPE=Debug -DCMAKE_TOOLCHAIN_FILE=\"$ANDROID_NDK_HOME/build/cmake/android.toolchain.cmake\" -DANDROID_ABI=\"$GRPC_ANDROID_ABI\" -DANDROID_PLATFORM=\"$GRPC_ANDROID_PLATFORM\" -DProtobuf_DIR=\"$GRPC_INSTALL_DIR/lib/cmake/protobuf\" -DgRPC_DIR=\"$GRPC_INSTALL_DIR/lib/cmake/grpc\" -DHOST_PROTOC=\"$GRPC_HOST_INSTALL_DIR/bin/protoc\" -DHOST_GRPC_CPP_PLUGIN=\"$GRPC_HOST_INSTALL_DIR/bin/grpc_cpp_plugin\" && cmake --build build-android",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Android Clean",
            "type": "shell",
            "command": "rm -rf build-android",
            "group": "build",
            "problemMatcher": []
        }
    ]
}